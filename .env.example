# URL base dos microserviços usados pela tela /secretaria
# Ajuste para as portas locais ou URLs do Azure Container Apps.
VITE_WHISPER_API_BASE_URL=""
VITE_LLM_API_BASE_URL=""
VITE_DATABASE_API_BASE_URL=""
VITE_LLM_CHAT_PATH=/chat/message

# Opcional: use "default" para manter o mesmo contexto durante a demo.
# Se remover esta variável, o frontend cria uma session_id por navegador.
VITE_LLM_SESSION_ID=default

# API base URL legada — mantida para compatibilidade com outras telas.
VITE_API_BASE_URL=""

# Tempo (ms) de simulação de delay nas requests mockadas ainda existentes em outras telas.
VITE_MOCK_DELAY=1200
